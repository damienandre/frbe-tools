# Copy to .env and fill in. The .env file is gitignored and never committed.

# Public API base URL (override only if the federation moves it).
FRBE_API_BASE=https://www.frbe-kbsb-ksb.be/api/v1

# Where consolidated data and the analytical database live.
FRBE_DATA_DIR=data
FRBE_DB_PATH=data/frbe.duckdb

# Credentials for the FRBE/KBSB "Players Manager" application, used by
# `frbe scrape` to download the database dumps. Log in at:
#   https://www.frbe-kbsb.be/sites/manager/GestionCOMMON/GestionLogin.php
FRBE_USERNAME=
FRBE_PASSWORD=
